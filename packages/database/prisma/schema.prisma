generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPERADMIN
  STORE_OWNER
  CASHIER
  VENDOR
  COURIER
}

enum CategoryStatus {
  ACTIVE
  HIDDEN
  ARCHIVED
}

enum SubcategoryStatus {
  ACTIVE
  PENDING
  REJECTED
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  DISCONTINUED
}

enum TagType {
  GENERAL
  BRAND
  DIET
  ORIGIN
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  pinCode   String?
  name      String
  role      UserRole @default(CASHIER)
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id])
  phone     String?
  emailVerified Boolean @default(false)
  verificationToken String?
  defaultPosMode String? @default("tables") 
  permissions    String[] @default(["POS"])
  assignedTables String[] @default([]) // Tables assigned to this barista (labels)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendorProfile  VendorProfile?
  courierProfile CourierProfile?
  paidSales     Sale[] @relation("paidBy")
  takenSales    Sale[] @relation("takenBy")
  preparedSales Sale[] @relation("preparedBy")
  sessionLogs   StaffSessionLog[]
  specialOrders SpecialOrder[] @relation("takenBy")
}

model StaffSessionLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  storeId   String
  action    String   // LOGIN, LOGOUT
  createdAt DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id])
  category    String   // "EAU_SONEDE", "STEG", "LOYER", "SALAIRE", "CNSS", "ACHAT", "AUTRE"
  amount      Decimal
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Store {
  id        String   @id @default(cuid())
  name      String
  subdomain String?  @unique
  address   String?
  city      String?
  phone     String?
  lat       Float?
  lng       Float?
  
  loyaltyEarnRate   Decimal?   @default(1)    // Earn rate: Points earned per 1 DT spent
  loyaltyRedeemRate Decimal?   @default(100)  // Redeem rate: Points required to get 1 DT discount
  
  status        String   @default("PENDING_DOCS") // PENDING_DOCS, PENDING_VERIFICATION, ACTIVE, SUSPENDED
  officialDocs  Json?    // Array of { name: string, url: string, type: string, status: string }
  trialEndsAt   DateTime?
  isVerified    Boolean  @default(false)
  forceMarketplaceAccess Boolean @default(false)

  // NACEF / Fiscal Requirements
  isFiscalEnabled Boolean  @default(false)
  currentFiscalSequence Int @default(0) // Compteur atomique pour la numérotation NACEF
  fiscalSecret    String?  // Secret de signature spécifique à la boutique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owners         User[]
  products       Product[]
  sales          Sale[]
  stockItems     StockItem[]
  suppliers      Supplier[]
  orders         SupplierOrder[]
  stockReports   StockReport[]
  expenses       Expense[]
  subscription   Subscription?
  tables         StoreTable[]
  terminals      PosTerminal[]
  categories     Category[]
  customers      Customer[]
  specialOrders  SpecialOrder[]
  zReports       ZReport[]

  activityPoleId String?

  activityPole   ActivityPole? @relation(fields: [activityPoleId], references: [id])

  // Anti-leakage tracking
  vendorInteractions     VendorInteraction[]     @relation("StoreInteractions")
  vendorRelationships    StoreVendorRelationship[] @relation("StoreRelationships")
}

model StoreTable {
  id        String   @id @default(cuid())
  label     String
  capacity  Int      @default(2)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id])
  createdAt DateTime @default(now())
}

model PosTerminal {
  id             String   @id @default(cuid())
  nickname       String   // ex: "Caisse Terrasse", "iPad Bar"
  activationCode String?  @unique // 6-digit code
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  status         String   @default("INACTIVE") // INACTIVE, ACTIVE, REVOKED
  lastUsedAt     DateTime?
  token          String?  // Long-term pairing token
  
  // NACEF keys
  publicKey      String?  // Store terminal's public key for signature verification
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  sales          Sale[]
  zReports       ZReport[]
}


model Plan {
  id            String         @id @default(cuid())
  name          String
  price         Decimal
  maxStores     Int            @default(1)
  maxProducts   Int            @default(50)
  hasMarketplace Boolean       @default(true)
  status        String         @default("ACTIVE")
  subscriptions Subscription[]
}

model Subscription {
  id        String   @id @default(cuid())
  storeId   String   @unique
  store     Store    @relation(fields: [storeId], references: [id])
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id])
  status    String   @default("ACTIVE")
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ActivityPole {
  id        String   @id @default(cuid())
  name      String   @unique
  icon      String?
  stores    Store[]
  vendors   VendorProfile[]
  createdAt DateTime @default(now())
}

// ============================================
// MARKETPLACE CATEGORIES SYSTEM
// ============================================

model MktCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String?
  description String?
  sortOrder   Int      @default(0)
  
  // Governance
  status      CategoryStatus @default(ACTIVE)
  isGlobal    Boolean  @default(true)
  
  subcategories MktSubcategory[]
  vendors       VendorProfile[] @relation("VendorSectors")
  createdAt   DateTime @default(now())

  @@index([status])
}

model MktSubcategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  
  categoryId  String
  category    MktCategory @relation(fields: [categoryId], references: [id])
  
  // Validation workflow
  status      SubcategoryStatus @default(ACTIVE)
  proposedBy  String?
  validatedBy String?
  
  createdAt   DateTime @default(now())
  
  @@unique([name, categoryId])
  @@index([categoryId])
  @@index([status])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  type      TagType  @default(GENERAL)
  usageCount Int     @default(0)
  
  createdAt  DateTime @default(now())
  
  @@index([type])
}

model ProductStandard {
  id              String   @id @default(cuid())
  name            String
  sku             String?  @unique
  
  categoryId      String
  subcategoryId  String?
  
  // Specs standardisées
  unit            String   // "kg", "L", "piece", "pack"
  defaultPrice    Decimal?
  
  brand           String?
  tags            String[] // Tags libres
  
  // Metadata
  isStandard      Boolean  @default(false)
  isActive        Boolean  @default(true)
  
  // Relation vers VendorProduct
  vendorProducts  VendorProduct[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([categoryId])
  @@index([subcategoryId])
}

model VendorProduct {
  id              String   @id @default(cuid())
  
  // Référence produit standard (optionnel - peut être produit libre)
  productStandardId String?
  productStandard   ProductStandard? @relation(fields: [productStandardId], references: [id])
  
  // Produit libre (si pas de standard)
  name            String?
  unit            String?
  
  // Catégorie associée
  categoryId      String?
  
  // Sous-catégorie associée
  subcategoryId  String?
  
  // Vendeur spécifique
  vendorId        String
  vendor          VendorProfile @relation(fields: [vendorId], references: [id])
  
  // Données spécifiques vendeur
  price           Decimal
  minOrderQty     Decimal  @default(1)
  stockStatus     StockStatus @default(IN_STOCK)
  
  // Offre
  isFeatured      Boolean  @default(false)
  isFlashSale     Boolean  @default(false)
  discountPrice   Decimal?
  flashStart      DateTime?
  flashEnd        DateTime?
  
  image           String?
  images          String[] @default([])
  description     String?
  
  // Tags (libres)
  tags            String[]
  
  // Zone livraison
  deliveryAreas   String[] // Villeslivrables
  
  // Métadonnées
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  bundleItems     MktBundleItem[]
  
  @@unique([productStandardId, vendorId])
  @@index([vendorId])
  @@index([stockStatus])
  @@index([categoryId])
}

model MktBundle {
  id              String   @id @default(cuid())
  name            String
  description     String?
  price           Decimal
  discountPercent Int?     // Optionnel: pour afficher l'économie
  image           String?
  images          String[] @default([])
  
  vendorId        String
  vendor          VendorProfile @relation(fields: [vendorId], references: [id])
  
  items           MktBundleItem[]
  
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([vendorId])
}

model VendorWallet {
  id        String   @id @default(cuid())
  vendorId  String   @unique
  vendor    VendorProfile @relation(fields: [vendorId], references: [id])
  balance   Decimal  @default(0)
  currency  String   @default("DT")
  status    String   @default("ACTIVE") // ACTIVE, SUSPENDED
  updatedAt DateTime @updatedAt
  
  transactions WalletTransaction[]
}

model WalletTransaction {
  id           String   @id @default(cuid())
  walletId     String
  wallet       VendorWallet @relation(fields: [walletId], references: [id])
  amount       Decimal  // positive for credit, negative for debit
  type         String   // DEPOSIT, COMMISSION, WITHDRAWAL, PENALTY, REFUND
  description  String?
  settlementId String?  @unique
  settlement   MarketplaceSettlement? @relation(fields: [settlementId], references: [id])
  createdAt    DateTime @default(now())

  @@index([walletId])
}

model MarketplaceSettlement {
  id              String   @id @default(cuid())
  orderId         String   @unique
  order           SupplierOrder @relation(fields: [orderId], references: [id])
  
  commissionAmount Decimal
  
  vendorApproved     Boolean @default(false)
  superadminApproved Boolean @default(false)
  
  isProcessed      Boolean @default(false)
  processedAt      DateTime?
  
  transaction      WalletTransaction?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================
// ANTI-LEAKAGE TRACKING — Phase 2
// ============================================

// Every touchpoint between a CoffeeShop and a Vendor is logged here.
// This is both an audit trail and the foundation for BehaviorScoring.
model VendorInteraction {
  id        String   @id @default(cuid())

  storeId   String
  store     Store    @relation("StoreInteractions", fields: [storeId], references: [id])

  vendorId  String
  vendor    VendorProfile @relation("VendorInteractions", fields: [vendorId], references: [id])

  // Type of interaction
  type      String
  // VIEW_PROFILE | VIEW_PRODUCT | SEND_MESSAGE | REQUEST_QUOTE | PLACE_ORDER | VIEW_CATALOG

  // Optional contextual data
  metadata  Json?
  // { productId, duration, source: 'search'|'featured'|'recommendation', sessionId }

  createdAt DateTime @default(now())

  @@index([storeId, vendorId])
  @@index([storeId])
  @@index([vendorId])
  @@index([type])
  @@index([createdAt])
}

// Formal relationship between a CoffeeShop and a Vendor.
// Status lifecycle: DISCOVERED → CONTACTED → ORDERED → ACTIVE → CHURNED
// discoveredAt is the legal proof the relationship started on-platform.
model StoreVendorRelationship {
  id              String   @id @default(cuid())

  storeId         String
  store           Store    @relation("StoreRelationships", fields: [storeId], references: [id])

  vendorId        String
  vendor          VendorProfile @relation("VendorRelationships", fields: [vendorId], references: [id])

  // Lifecycle status
  status          String   @default("DISCOVERED")
  // DISCOVERED | CONTACTED | ORDERED | ACTIVE | CHURNED | SUSPENDED

  // Key timestamps (immutable once set — legal proof)
  discoveredAt    DateTime @default(now())
  firstContactAt  DateTime?
  firstOrderAt    DateTime?
  lastOrderAt     DateTime?
  lastActivityAt  DateTime?

  // Aggregated metrics (updated on each interaction/order)
  totalInteractions Int    @default(0)
  totalOrders       Int    @default(0)
  totalRevenue      Decimal @default(0)

  // BehaviorScoring — 0 (safe) to 100 (high leakage risk)
  leakageRiskScore  Int    @default(0)

  // Flags
  isFlagged         Boolean @default(false)  // Manually flagged by superadmin
  flagReason        String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([storeId, vendorId])
  @@index([leakageRiskScore])
  @@index([status])
  @@index([isFlagged])
}
model WalletDepositRequest {
  id          String   @id @default(cuid())
  vendorId    String
  vendor      VendorProfile @relation(fields: [vendorId], references: [id])
  amount      Decimal
  proofImage  String?  // URL to the uploaded proof
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([vendorId])
}

model MktBundleItem {
  id              String   @id @default(cuid())
  bundleId        String
  bundle          MktBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  
  vendorProductId String
  vendorProduct   VendorProduct @relation(fields: [vendorProductId], references: [id])
  
  quantity        Decimal
  
  createdAt       DateTime @default(now())

  @@index([bundleId])
  @@index([vendorProductId])
}

model Category {
  id        String    @id @default(cuid())
  name      String
  color     String?   @default("#6366F1") // Couleur pour le POS
  icon      String?
  storeId   String?
  store     Store?    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products  Product[]
  parentId  String?
  parent    Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@index([storeId])
  @@index([parentId])
}

model Product {
  id         String   @id @default(cuid())
  name       String
  price      Decimal
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id])

  // ── Champs Fiscaux NACEF ──────────────────────────────────────
  taxRate    Decimal  @default(0.19)     // Taux TVA: 0, 0.07, 0.19
  taxCode    String?                     // Code TVA optionnel: "A", "B", "C"
  // ─────────────────────────────────────────────────────────────

  recipe RecipeItem[]
  sales     SaleItem[]
  unitId     String?
  unit       GlobalUnit? @relation(fields: [unitId], references: [id])
  icon       String?
  image      String?
  active     Boolean  @default(true)
  canBeTakeaway Boolean @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  specialOrders SpecialOrder[]
}

// Ingrédients constitutifs d'un produit (Recette)
model RecipeItem {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])
  quantity    Decimal   // ex: 0.018 kg de café pour un expresso

  // Emballage : si true → ne décompter que si consumeType = TAKEAWAY
  isPackaging Boolean @default(false)
  // BOTH = toujours décompté | DINE_IN = sur place only | TAKEAWAY = à emporter only
  consumeType String  @default("BOTH")
}

model Sale {
  id        String     @id @default(cuid())
  total     Decimal
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id])
  tableName String?
  baristaId String?
  barista   User?      @relation("paidBy", fields: [baristaId], references: [id])
  takenById String?
  takenBy   User?      @relation("takenBy", fields: [takenById], references: [id])
  customerId    String?
  customer      Customer?  @relation(fields: [customerId], references: [id])
  
  subtotal      Decimal?
  discount      Decimal?
  paymentMethod String?   // "CASH" | "CARD" | "LOYALTY" | "MIXED"
  paymentDetails Json?    // { cash: amount, card: amount, points: amount }
  
  items         SaleItem[]
  createdAt     DateTime   @default(now())

  // Préparateur (Bar/Kitchen Display System)
  preparationStatus  String?   @default("PENDING") // PENDING, IN_PROGRESS, READY, SERVED
  paymentStatus      String?   @default("PAID")    // PAID, UNPAID, CANCELLED
  preparedById       String?
  preparedBy         User?     @relation("preparedBy", fields: [preparedById], references: [id])
  preparedAt         DateTime?
  preparationStation String?   // "bar", "chicha", "cuisine" — multi-poste
  mode               String?   @default("NORMAL") // NORMAL, RACHMA
  consumeType        String?   @default("DINE_IN") // DINE_IN | TAKEAWAY

  // ── Champs Fiscaux NACEF ────────────────────────────────────
  isFiscal           Boolean   @default(false)
  fiscalNumber       String?   // Numéro séquentiel (ex: FAC-2026-000001)
  sequenceNumber     Int?      // Numéro de séquence entier
  fiscalDay          String?   // Jour fiscal (ex: "2026-04-18")
  terminalId         String?
  terminal           PosTerminal? @relation(fields: [terminalId], references: [id])
  deviceId           String?   // Identifiant appareil POS
  sessionId          String?   // Identifiant session caisse
  hash               String?   // SHA-256 (chainage)
  previousHash       String?   // Hash de la vente précédente
  hashInput          String?   // Données brutes utilisées pour le hash
  signature          String?   // Signature HMAC du terminal
  isVoid             Boolean   @default(false) // Ticket annulé
  change             Decimal?  // Monnaie rendue au client

  // ── Totaux Fiscaux ──────────────────────────────────────────
  totalHt            Decimal?  // Total HT global
  totalTax           Decimal?  // Total TVA global
  taxBreakdown       Json?     // Ventilation par taux { "7": 1.5, "19": 10.2 }
  zReportId          String?
  zReport            ZReport?   @relation(fields: [zReportId], references: [id])
  appVersion         String?   // Version de l'app au moment de la vente
  // ──────────────────────────────────────────────────────────

  fiscalLogs         FiscalLog[]

  @@unique([storeId, sequenceNumber])
  @@index([fiscalDay])
}

model FiscalLog {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  action    String   // "CREATE", "CANCEL", "ERROR"
  data      Json?    // Snapshot of data at time of log
  hash      String?  // Log integrity hash
  createdAt DateTime @default(now())
}

model ZReport {
  id              String      @id @default(cuid())
  storeId         String
  store           Store       @relation(fields: [storeId], references: [id])
  terminalId      String?
  terminal        PosTerminal? @relation(fields: [terminalId], references: [id])
  
  reportDay       String      // "YYYY-MM-DD"
  date            DateTime    @default(now()) // Timestamp of report generation
  totalTtc        Decimal
  totalHt         Decimal
  totalTax        Decimal
  taxBreakdown    Json        // Breakdown per tax rate { "7%": value, "19%": value }
  salesCount      Int
  
  isClosed        Boolean     @default(true)
  hashInput       String?     // Input used for hashing
  hash            String?     // Integrity hash for the report
  previousZHash   String?     // Chain of Z-Reports
  
  sales           Sale[]
  
  createdAt       DateTime    @default(now())
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal                // Prix TTC unitaire (tel que vendu)

  // ── Champs Fiscaux NACEF (calculés au moment de la vente) ────
  unitPriceHt  Decimal?           // Prix HT unitaire = price / (1 + taxRate)
  taxRate      Decimal?           // Taux TVA appliqué
  taxAmount    Decimal?           // Montant TVA = totalHt × taxRate
  totalHt      Decimal?           // Total HT = qty × unitPriceHt
  totalTtc     Decimal?           // Total TTC = totalHt + taxAmount
  // ─────────────────────────────────────────────────────────────
}

// Articles en stock (ex: Grains de café, Lait, Gobelets)
model StockItem {
  id           String  @id @default(cuid())
  name         String
  unitId       String?
  unit         GlobalUnit? @relation(fields: [unitId], references: [id])
  quantity     Decimal @default(0)
  cost         Decimal @default(0)
  minThreshold Decimal @default(0)
  storeId      String
  store        Store   @relation(fields: [storeId], references: [id])
  
  preferredVendorId String?
  preferredVendor   VendorProfile? @relation(fields: [preferredVendorId], references: [id])

  preferredSupplierId String?
  preferredSupplier   Supplier? @relation(fields: [preferredSupplierId], references: [id])

  recipeItems RecipeItem[]
  orderItems  SupplierOrderItem[]
  stockReportDetails StockReportDetail[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model StockReport {
  id             String      @id @default(cuid())
  storeId        String
  store          Store       @relation(fields: [storeId], references: [id])
  type           String      // "INVENTORY_CHECK", "WASTE", "ADJUSTMENT"
  notes          String?
  createdAt      DateTime    @default(now())
  details        StockReportDetail[]
}

model StockReportDetail {
  id             String      @id @default(cuid())
  reportId       String
  report         StockReport @relation(fields: [reportId], references: [id])
  stockItemId    String
  stockItem      StockItem   @relation(fields: [stockItemId], references: [id])
  quantityBefore Decimal
  quantityAfter  Decimal
}

model VendorProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id])
  companyName String
  description String?
  address     String?
  city        String?
  phone       String?
  lat         Float?
  lng         Float?

  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  activityPoles ActivityPole[]
  mktSectors    MktCategory[]  @relation("VendorSectors")

  vendorProducts VendorProduct[]
  bundles        MktBundle[]
  orders         SupplierOrder[]
  stockItems     StockItem[]
  
  wallet         VendorWallet?
  commissionRate Decimal @default(0.01) // Negotiation margin (per order total)
  commissionTiers Json?  // Format: [{ minAmount: number, rate: number }]
  depositRequests WalletDepositRequest[]

  // Anti-leakage tracking
  interactions   VendorInteraction[]     @relation("VendorInteractions")
  relationships  StoreVendorRelationship[] @relation("VendorRelationships")
}

model CourierProfile {
  id          String          @id @default(cuid())
  userId      String          @unique
  user        User            @relation(fields: [userId], references: [id])
  vehicleType String
  status      String          @default("AVAILABLE")
  currentLat  Float?
  currentLng  Float?
  orders      SupplierOrder[]
  createdAt   DateTime        @default(now())
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  PAID
}

model Supplier {
  id      String          @id @default(cuid())
  name    String
  contact String?
  phone   String?
  orders  SupplierOrder[]
  stockItems StockItem[]
  storeId    String?
  store      Store?          @relation(fields: [storeId], references: [id])
  createdAt  DateTime      @default(now())
}

model SupplierOrder {
  id      String      @id @default(cuid())
  status  OrderStatus @default(PENDING)
  total   Decimal
  storeId String
  store   Store       @relation(fields: [storeId], references: [id])

  // Marketplace link
  vendorId String?
  vendor   VendorProfile? @relation(fields: [vendorId], references: [id])

  // Legacy / Manual link
  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  courierId     String?
  courier       CourierProfile? @relation(fields: [courierId], references: [id])
  needsDelivery Boolean           @default(false)
  items         SupplierOrderItem[]
  settlement    MarketplaceSettlement?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model SupplierOrderItem {
  id          String        @id @default(cuid())
  orderId     String
  order       SupplierOrder @relation(fields: [orderId], references: [id])
  stockItemId String?
  stockItem   StockItem?    @relation(fields: [stockItemId], references: [id])
  name        String? // Name of product if not linked to stockItem
  quantity    Decimal
  price       Decimal
  mktBundleId String?
  mktProductId String?
}
model GlobalUnit {
  id        String      @id @default(cuid())
  name      String      @unique
  products  Product[]
  stockItems StockItem[]
  createdAt DateTime    @default(now())
}

model Customer {
  id             String   @id @default(cuid())
  name           String
  phone          String
  email          String?
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id])
  loyaltyPoints  Int      @default(0)
  totalSpent     Decimal  @default(0)
  notes          String?
  sales          Sale[]
  specialOrders  SpecialOrder[]
  loyaltyTx      LoyaltyTransaction[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([phone, storeId])
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  saleId      String?
  points      Int      // + gain, - redeem
  reason      String   // "PURCHASE" | "REDEEM" | "MANUAL"
  createdAt   DateTime @default(now())
}

enum SpecialOrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  READY
  DELIVERED
  CANCELLED
}

model SpecialOrder {
  id              String             @id @default(cuid())
  orderNumber     String             @unique
  storeId         String
  store           Store              @relation(fields: [storeId], references: [id])
  customerId      String?
  customer        Customer?          @relation(fields: [customerId], references: [id])
  
  clientName      String?
  clientPhone     String?
  
  productId       String?
  product         Product?           @relation(fields: [productId], references: [id])
  productName     String             
  quantity        Decimal            @default(1)
  unitPrice       Decimal
  totalPrice      Decimal
  
  customFields    Json?              
  notes           String?
  
  deliveryDate    DateTime           
  deliveryTime    String?            
  isDelivery      Boolean  @default(false)
  deliveryAddress String?
  
  depositAmount   Decimal  @default(0)  
  depositPaidAt   DateTime?
  depositMethod   String?  
  status          SpecialOrderStatus @default(PENDING)
  
  takenById       String?
  takenBy         User?              @relation("takenBy", fields: [takenById], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
