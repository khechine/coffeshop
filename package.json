{
  "name": "coffeeshop-b2b",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate --filter=@coffeeshop/database",
    "db:push": "turbo run db:push --filter=@coffeeshop/database",
    "db:studio": "pnpm --filter @coffeeshop/database db:studio",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@prisma/client": "5.14.0",
    "prisma": "5.14.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "tmp@<=0.2.3": ">=0.2.4",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "tar@<7.5.7": ">=7.5.7",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "webpack@>=5.49.0 <=5.104.0": ">=5.104.1",
      "webpack@>=5.49.0 <5.104.0": ">=5.104.0",
      "tar@<=7.5.2": ">=7.5.3",
      "tar@<7.5.8": ">=7.5.8",
      "multer@<2.1.0": ">=2.1.0",
      "multer@<2.1.1": ">=2.1.1",
      "tar@<=7.5.9": ">=7.5.10",
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1",
      "tar@<=7.5.10": ">=7.5.11",
      "tar@<=7.5.3": ">=7.5.4",
      "file-type@>=20.0.0 <=21.3.1": ">=21.3.2",
      "node-forge@<=1.3.3": ">=1.4.0",
      "node-forge@<1.4.0": ">=1.4.0",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0"
    }
