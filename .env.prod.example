# .env.prod.example - TEMPLATE FOR PRODUCTION ENVIRONMENT
# ⚠️ DO NOT COMMIT THIS FILE WITH REAL VALUES
# Copy this file to .env.prod and replace all XXXX values with actual credentials
# Store .env.prod in secure location (e.g., vault, secrets manager, encrypted storage)

# PostgreSQL Configuration
# Generate with: openssl rand -hex 16
POSTGRES_USER=postgres
POSTGRES_PASSWORD=XXXXXXXXXXXXXXXX_REPLACE_WITH_SECURE_PASSWORD_XXXXXXXXXXXXXXXX

# Database Connection
DATABASE_URL="postgresql://postgres:XXXXXXXXXXXXXXXX_REPLACE_WITH_SECURE_PASSWORD_XXXXXXXXXXXXXXXX@coffeeshop_db:5432/coffeeshop?schema=public"

# JWT Authentication Secret  
# Generate with: openssl rand -base64 32
JWT_SECRET=XXXXXXXXXXXXXXXX_REPLACE_WITH_32_BYTE_RANDOM_STRING_XXXXXXXXXXXXXXXX

# Next.js API Configuration
NEXT_PUBLIC_APP_URL="https://api.coffeeshop.elkassa.com"
PORT=3001
NODE_ENV=production

# GitHub Integration (if used)
# Keep these values from original .env, or regenerate
github_token=XXXXXXXXXXXXXXXX_REPLACE_WITH_GITHUB_TOKEN_XXXXXXXXXXXXXXXX
github_user=khechine

# Deployment Configuration
ssh_server=debian@vps-08df0a26.vps.ovh.net
ssh_folder=/home/debian/coffeshop/
domain_name=coffeeshop.elkassa.com
